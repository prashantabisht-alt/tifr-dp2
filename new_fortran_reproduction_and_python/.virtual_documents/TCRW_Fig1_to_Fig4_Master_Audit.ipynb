


from __future__ import annotations
from pathlib import Path
import datetime as _dt

ROOT = Path.cwd()

def exists_size(path):
    p = ROOT / path
    if not p.exists():
        return False, None, None
    return True, p.stat().st_size / 1024 / 1024, _dt.datetime.fromtimestamp(p.stat().st_mtime).strftime("%Y-%m-%d %H:%M")

ROOT






notebooks = [
    "Fig1_TCRW_reproduction_audit.ipynb",
    "Fig2_TCRW_reproduction_audit.ipynb",
    "Fig3_TCRW_reproduction_audit.ipynb",
    "Fig4_TCRW_reproduction_audit.ipynb",
]
print("notebook                              exists  size_MB  modified")
for name in notebooks:
    ok, size, mtime = exists_size(name)
    print(f"{name:38s} {str(ok):>6s} {size if size is not None else float('nan'):8.3f}  {mtime or '-'}")
assert all((ROOT / name).exists() for name in notebooks)






