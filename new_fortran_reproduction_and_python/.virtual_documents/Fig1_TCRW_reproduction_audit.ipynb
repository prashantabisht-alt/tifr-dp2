


from __future__ import annotations
from pathlib import Path
import os
import textwrap
import numpy as np

ROOT = Path.cwd()

def data_rows(path):
    with open(path) as f:
        return sum(1 for line in f if line.strip() and not line.startswith("#"))

def artifact_report(paths):
    print("artifact                                  exists  size_MB  modified")
    for raw in paths:
        p = ROOT / raw
        exists = p.exists()
        size = p.stat().st_size / 1024 / 1024 if exists else float("nan")
        mtime = __import__("datetime").datetime.fromtimestamp(p.stat().st_mtime).strftime("%Y-%m-%d %H:%M") if exists else "-"
        print(f"{raw:42s} {str(exists):>6s} {size:8.3f}  {mtime}")

def source_head(path, n=70):
    p = ROOT / path
    print(f"--- {path} ---")
    with open(p, "r", errors="replace") as f:
        for i, line in zip(range(n), f):
            print(line.rstrip())












artifact_report([
    "tcrw_fig1b.pdf", "tcrw_fig1c.pdf", "tcrw_fig1d.pdf",
    "tcrw_fig1b_pymc.png", "tcrw_fig1c_pymc.png", "tcrw_fig1d_pymc.png",
    "tcrw_fig1d_crosscheck.png",
    "../tmp/pdfs/tcrw_fig1b_fortran.png", "../tmp/pdfs/tcrw_fig1c_fortran.png", "../tmp/pdfs/tcrw_fig1d_fortran.png",
])



print("Data-file row checks")
for p in sorted(ROOT.glob("tcrw_fig1b_traj_w*.txt")):
    print(f"{p.name:32s} rows={data_rows(p):8d} expected=1000001")
for p in sorted(ROOT.glob("tcrw_fig1c_msd_w*.txt")):
    print(f"{p.name:32s} rows={data_rows(p):8d} expected=100")
for p in sorted(ROOT.glob("tcrw_fig1d_D_dr*.txt")):
    print(f"{p.name:32s} rows={data_rows(p):8d} expected=11")



print("Diffusion-table read-only summary")
for name in ["tcrw_fig1d_D_dr3.txt", "tcrw_fig1d_D_dr2.txt"]:
    arr = np.loadtxt(name, comments="#")
    peak = arr[np.argmax(arr[:, 1])]
    endpoints = arr[[0, -1], 1]
    print(f"{name}: peak D={peak[1]:.5f} at omega={peak[0]:.2f}; endpoint Ds={endpoints[0]:.3e}, {endpoints[1]:.3e}")






source_head("tcrw_fig1b.f90", n=55)
